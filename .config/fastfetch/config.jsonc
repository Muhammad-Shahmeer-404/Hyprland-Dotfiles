{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "type": "auto",        // Logo type: auto, builtin, small, file, etc.
    "source": "~/.config/fastfetch/half_life_lamba_logo.txt",      // Built-in logo name or file path
    "width": 5,           // Width in characters
    "height": 5,          // Height in characters
    "padding": {
        "top": 0,          // Top padding
        "left": 0,         // Left padding
        "right": 0         // Right padding
    },
    "color": {             // Override logo colors
        "1": "dim_",
        "2": "dim_"
    }

  },

  "display": {
    "separator": ": "
},

  
  "modules": [
    {
        "type": "custom",
        "format": "\u001b[32mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖHardwareв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
        
    },
    {
        "type": "host",
        "key" : "у°Ңў PC ",
        "format" : "{name}",
        "keyColor" : "green"
    },
    {
        "type"  : "cpu",
        "key"   : "в”Ӯ в”ңп’ј ",
        "format": "{name}",
        "keyColor" : "green"
    },
    {
        "type"   : "gpu",
        "key"    : "в”Ӯ в”ңу°ҫІ ",
        "format" : "{name}",
        "keyColor" : "green"
    },
    {
        "type"  : "memory",
        "key"   : "в”Ӯ в”ңоҝ… ",
        "format": "{used} / {total}",
        "keyColor": "green"
    },
    {
        "type"  : "disk",
        "key"   : "в”Ӯ в”ңпӮ  ",
        "format": "{size-used} / {size-total}",
        "keyColor": "green"
    },

    {
        "type" : "custom",
        "format": "\u001b[32mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
    },
    "break",
    {
        "type": "custom",
        "format": "\u001b[33mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖSoftwareв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
    },
    {
        "type": "os",
        "key" : "п…ј OS ",
        "format": "{name}",
        "keyColor": "yellow"
    },
    {
        "type": "shell",
        "key" : "в”Ӯ в”ңп’ү ",
        "format" : "{process-name}",
        "keyColor": "yellow"
    },
    {
        "type": "kernel",
        "key" : "в”Ӯ в”ңпҖ“ ",
        "format": "{sysname} {release}",
        "keyColor": "yellow"
    },
    {
        "type": "wm",
        "key": "в”Ӯ в”ңп’Ҳ ",
        "format": "{process-name} ({protocol-name})",
        "keyColor": "yellow"
    },
    {
        "type": "packages",
        "key" : "в”Ӯ в”ңу°Ҹ– ",
        "format" : "Pacman: {pacman} | Flatpack: {flatpak-all}",
        "keyColor": "yellow"
    },
    {
        "type" : "custom",
        "format": "\u001b[33mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
    },
    "break",
    {
        "type": "custom",
        "format": "\u001b[32mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖAge/Uptimeв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
    },
    {
        "type": "command",
        "key": "в”Ӯ > OS Age ",
        "keyColor": "green",
        "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days"
    },
    {
        "type": "uptime",
        "key": "в”Ӯ > оҷҒ ",
        "keyColor": "green"
    },
    {
        "type" : "custom",
        "format": "\u001b[32mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
    },
    "break",
    {
        "type": "colors",
        "paddingLeft": 2,
        "symbol": "circle"
    }
  ]
}
